# ============================================================
# MangoPi M28C / Widora M28C - 目标平台与构建选项
# 由用户上传的 m28c.config 拆分生成。
# 软件包条目请见 profiles/m28c/packages.txt。
# ============================================================

# 目标平台：Rockchip / ARMv8 / MangoPi M28C
CONFIG_TARGET_rockchip=y
CONFIG_TARGET_rockchip_armv8=y
CONFIG_TARGET_rockchip_armv8_DEVICE_widora_mangopi-m28c=y
CONFIG_TARGET_BOARD="rockchip"
CONFIG_TARGET_SUBTARGET="armv8"
CONFIG_TARGET_PROFILE="DEVICE_widora_mangopi-m28c"

# 不启用多设备 Profile，只编译 MangoPi M28C 一个设备
# CONFIG_TARGET_MULTI_PROFILE is not set

# ============================================================
# 固件文件系统与镜像格式
# ============================================================

# 使用 SquashFS 只读根文件系统，这是 OpenWrt 常见固件格式
CONFIG_TARGET_ROOTFS_SQUASHFS=y

# Rootfs 分区大小，单位 MB
CONFIG_TARGET_ROOTFS_PARTSIZE=2048

# 不生成 ext4 固件，只保留 squashfs
# CONFIG_TARGET_ROOTFS_EXT4FS is not set

# 生成 gzip 压缩镜像，例如 sysupgrade.img.gz
CONFIG_TARGET_IMAGES_GZIP=y

# ============================================================
# 编译辅助功能
# ============================================================

# 启用 ccache，加快二次编译速度
CONFIG_CCACHE=y

# 保存详细编译日志，方便排错
CONFIG_BUILD_LOG=y

# ============================================================
# eBPF / BTF 内核功能
# ============================================================

# 启用开发者选项，让更多内核调试/高级选项出现
CONFIG_DEVEL=y

# 编译内核调试信息
CONFIG_KERNEL_DEBUG_INFO=y

# 不压缩/裁剪调试信息，否则 BTF 可能无法正常生成
# CONFIG_KERNEL_DEBUG_INFO_REDUCED is not set

# 生成 BTF 类型信息，eBPF 程序、bpftool、CO-RE 生态常用
CONFIG_KERNEL_DEBUG_INFO_BTF=y

# BPF event 支持
CONFIG_KERNEL_BPF_EVENTS=y

# 启用 cgroups
CONFIG_KERNEL_CGROUPS=y

# 允许 eBPF 程序挂载到 cgroup
CONFIG_KERNEL_CGROUP_BPF=y

# XDP socket 支持，部分高性能 eBPF 网络程序会用到
CONFIG_KERNEL_XDP_SOCKETS=y
